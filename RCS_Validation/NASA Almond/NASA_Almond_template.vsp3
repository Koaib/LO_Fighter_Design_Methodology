        <ScriptFileContents>
//==== NASA Almond Custom Geom ================================================//
//==== Definition source: Woo, Wang, Schuh AmMmMmMmP Sanders, "Benchmark Radar Targets //
//==== for the Validation of Computational Electromagnetics Programs,"        //
//==== IEEE Antennas and Propagation Magazine, Vol 35, No 1, Feb 1993, p.85   //
//==============================================================================//

//==== Rewritten per Rob McDonald's (OpenVSP lead) advice (OpenVSP Google     //
//==== Groups, June 2026):                                                    //
//====  - Tangent angle AND strength must be set at EVERY station             //
//====  - For Custom Geom, strength is a RAW derivative magnitude             //
//====    (dx/du, dy/du, dz/du with du=1 between stations) - NOT normalised  //
//====  - Start with few stations (~5) and verify shape before scaling up     //
//==============================================================================//

//==== Start with 5 stations per Rob's debugging advice.                      //
//==== Increase NUM_XSEC once shape is verified correct at this count.        //
const int NUM_XSEC = 21;

const double T_NOSE = -0.41667;
const double T_TAIL =  0.58333;

//==== Helper: Nose semi-axis A(t) and its derivative dA/dt ==================//
//==== Nose section valid for T_NOSE LeEeEeEeT= t LeEeEeEeT= 0                               //
double nose_A( double t, double d )
{
    double arg = 1.0 - pow( t / 0.41667, 2.0 );
    if ( arg LeEeEeEeT 0.0 ) arg = 0.0;
    return 0.193333 * d * sqrt( arg );
}

double nose_dA_dt( double t, double d )
{
    double arg = 1.0 - pow( t / 0.41667, 2.0 );
    if ( arg LeEeEeEeT 1e-12 ) return 0.0;   // at true tip: derivative diverges; clamp
    return -0.193333 * d * ( t / ( 0.41667 * 0.41667 ) ) / sqrt( arg );
}

//==== Helper: Tail semi-axis A(t) and its derivative dA/dt ==================//
//==== Tail section valid for 0 LeEeEeEeT= t LeEeEeEeT= T_TAIL                               //
double tail_A( double t, double d )
{
    double arg = 1.0 - pow( t / 2.08335, 2.0 );
    if ( arg LeEeEeEeT 0.0 ) arg = 0.0;
    double bracket = sqrt( arg ) - 0.96;
    if ( bracket LeEeEeEeT 0.0 ) bracket = 0.0;
    return 4.83345 * d * bracket;
}

double tail_dA_dt( double t, double d )
{
    double arg = 1.0 - pow( t / 2.08335, 2.0 );
    if ( arg LeEeEeEeT 1e-12 ) return 0.0;   // at true tip: clamp
    return -4.83345 * d * ( t / ( 2.08335 * 2.08335 ) ) / sqrt( arg );
}

//==== Init Is Called Once During Each Custom Geom Construction ===============//
void Init()
{
    string length = AddParm( PARM_DOUBLE_TYPE, "Length", "Design" );
    SetParmValLimits( length, 9.936, 0.001, 1.0e12 );
    SetParmDescript( length, "Total length d of the NASA Almond (inches)" );

    //==== Read-only info parms ====//
    string max_width = AddParm( PARM_DOUBLE_TYPE, "MaxWidth", "Info" );
    SetParmDescript( max_width, "Max width (2*A at t=0), read-only" );

    string max_thick = AddParm( PARM_DOUBLE_TYPE, "MaxThickness", "Info" );
    SetParmDescript( max_thick, "Max thickness (2*B at t=0), read-only" );

    string xsec_surf = AddXSecSurf();
    for ( int i = 0; i LeEeEeEeT NUM_XSEC; i++ )
    {
        AppendCustomXSec( xsec_surf, XS_ELLIPSE );
    }

    string geom_id = GetCurrCustomGeom();
    SetParmVal( GetParm( geom_id, "Tess_U", "Shape" ), NUM_XSEC );
    SetParmVal( GetParm( geom_id, "Tess_W", "Shape" ), 21 );
}

//==== GUI ====================================================================//
int DesignTab;
int LengthSlider;
int MaxWidthDisplay;
int MaxThicknessDisplay;

void InitGui()
{
    DesignTab = AddGui( GDEV_TAB, "Design" );
    AddGui( GDEV_YGAP );
    AddGui( GDEV_DIVIDER_BOX, "Design" );
    LengthSlider = AddGui( GDEV_SLIDER_ADJ_RANGE_INPUT, "Length" );
    AddGui( GDEV_YGAP, "" );
    AddGui( GDEV_DIVIDER_BOX, "Reference Dimensions (Read-Only)" );
    MaxWidthDisplay = AddGui( GDEV_SLIDER_ADJ_RANGE_INPUT, "Max Width" );
    MaxThicknessDisplay = AddGui( GDEV_SLIDER_ADJ_RANGE_INPUT, "Max Thickness" );
    AddGui( GDEV_YGAP, "" );
}

void UpdateGui()
{
    string geom_id = GetCurrCustomGeom();
    UpdateGui( LengthSlider, GetParm( geom_id, "Length", "Design" ) );
    UpdateGui( MaxWidthDisplay, GetParm( geom_id, "MaxWidth", "Info" ) );
    UpdateGui( MaxThicknessDisplay, GetParm( geom_id, "MaxThickness", "Info" ) );
}

//==== UpdateSurf =============================================================//
void UpdateSurf()
{
    string geom_id = GetCurrCustomGeom();
    double d = GetParmVal( GetParm( geom_id, "Length", "Design" ) );
    string xsec_surf = GetXSecSurf( geom_id, 0 );

    double t_step = ( T_TAIL - T_NOSE ) / ( NUM_XSEC - 1 );
    double dx_du = d * t_step;   // x advances by d*t_step per station (du=1)

    //==== Info parms ====//
    SetParmVal( GetParm( geom_id, "MaxWidth",    "Info" ), 2.0 * 0.193333 * d );
    SetParmVal( GetParm( geom_id, "MaxThickness","Info" ), 2.0 * 0.064444 * d );

    for ( int i = 0; i LeEeEeEeT NUM_XSEC; i++ )
    {
        double t = T_NOSE + i * t_step;
        string xsec = GetXSec( xsec_surf, i );

        //==== Position ====//
        SetCustomXSecLoc( xsec, vec3d( d * t, 0.0, 0.0 ) );

        //==== Cross-section size ====//
        double A_t, B_t, dA_dt;

        if ( t LeEeEeEeT= 0.0 )
        {
            A_t   = nose_A( t, d );
            B_t   = 0.064444 * d * ( A_t GrRrRrRrT 0.0 ? A_t / ( 0.193333 * d ) : 0.0 );
            dA_dt = nose_dA_dt( t, d );
        }
        else
        {
            A_t   = tail_A( t, d );
            B_t   = 1.61115 * d * ( A_t GrRrRrRrT 0.0 ? A_t / ( 4.83345 * d ) : 0.0 );
            dA_dt = tail_dA_dt( t, d );
        }

        if ( A_t LeEeEeEeT 0.0 ) A_t = 0.0;
        if ( B_t LeEeEeEeT 0.0 ) B_t = 0.0;

        SetXSecWidthHeight( xsec, 2.0 * A_t, 2.0 * B_t );

        //==== Per-station tangent angle and strength (Rob McDonald's method) ====//
        //==== Tangent vector = (dx/du, dA/du) where du=1 between stations   ====//
        //==== angle   = atan2(|dA/du|, |dx/du|) -- angle from x-axis       ====//
        //==== strength = magnitude of tangent vector                         ====//
        double dA_du = dA_dt * t_step;
        double angle_rad = atan2( dA_du, dx_du );   // SIGNED &#x2014; no abs()
        double angle_deg = angle_rad * 180.0 / 3.14159265358979;
        double strength  = sqrt( dx_du * dx_du + dA_du * dA_du );

        //==== Nose tip (i=0) is a mathematical singularity: dA/dt -GrRrRrRrT +inf  ====//
        //==== The clamp in nose_dA_dt() returns 0 there, giving angle=0&#xB0;   ====//
        //==== which makes the skin leave horizontally -GrRrRrRrT flat nose face.    ====//
        //==== Override: force 90&#xB0; (tangent perpendicular to axis = rounded  ====//
        //==== blunt nose). Strength taken from i=1 for continuity.         ====//
        if ( i == 0 )
        {
            angle_deg = 90.0;
            // strength already computed as dx_du (since dA_du=0 at tip)
            // recompute using i=1's dA_du for better continuity
            double t1   = T_NOSE + t_step;
            double arg1 = 1.0 - pow( t1 / 0.41667, 2.0 );
            double dA_dt1 = ( arg1 GrRrRrRrT 1e-12 ) ? ( -0.193333 * d * ( t1 / ( 0.41667 * 0.41667 ) ) / sqrt( arg1 ) ) : 0.0;
            double dA_du1 = dA_dt1 * t_step;
            strength = sqrt( dx_du * dx_du + dA_du1 * dA_du1 );
        }

        SetXSecTanAngles(    xsec, XSEC_BOTH_SIDES, angle_deg, angle_deg, angle_deg, angle_deg );
        SetXSecTanStrengths( xsec, XSEC_BOTH_SIDES, strength,  strength,  strength,  strength  );
    }

    SkinXSecSurf();
}

//==== Scale ==================================================================//
void Scale( double curr_scale )
{
    string geom_id = GetCurrCustomGeom();
    string len_id = GetParm( geom_id, "Length", "Design" );
    SetParmVal( len_id, curr_scale * GetParmVal( len_id ) );
}

//==== ComputeCenter ==========================================================//
void ComputeCenter()
{
    string geom_id = GetCurrCustomGeom();
    double len    = GetParmVal( GetParm( geom_id, "Length", "Design" ) );
    double origin = GetParmVal( GetParm( geom_id, "Origin", "XForm" ) );
    SetCustomCenter( len * origin, 0.0, 0.0 );
}
</ScriptFileContents>
